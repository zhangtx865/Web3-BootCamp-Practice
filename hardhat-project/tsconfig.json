{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "outDir": "dist",
    "rootDir": ".",

    "types": ["node", "mocha"]
  },
  "include": [
    "./scripts",
    "./test",
    "./hardhat.config.ts",
    "./typechain-types"
  ]
}